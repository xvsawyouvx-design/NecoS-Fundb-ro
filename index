function showToast(msg, type='info') {
  const t = document.getElementById('toast');
  const el = document.createElement('div');
  el.className = `toast-item ${type}`;
  el.innerHTML = `${type==='success'?'✅':type==='error'?'❌':'ℹ️'} ${msg}`;
  t.appendChild(el);
  setTimeout(()=>el.remove(), 3500);
}
window.showToast = showToast;

function typeTag(type) {
  const m={event:'tag-green',meeting:'tag-blue',wartung:'tag-orange',sonstiges:'tag-blue'};
  const l={event:'🎉 Event',meeting:'💬 Meeting',wartung:'🔧 Wartung',sonstiges:'📌 Sonstiges'};
  return `<span class="tag ${m[type]||'tag-blue'}">${l[type]||type}</span>`;
}
function statusTag(s) {
  const m={offen:'tag-orange',gefunden:'tag-blue',abgeholt:'tag-green',aktiv:'tag-red',abgelaufen:'tag-green'};
  const l={offen:'⏳ Offen',gefunden:'🔍 Gefunden',abgeholt:'✅ Abgeholt',aktiv:'🔨 Aktiv',abgelaufen:'✔️ Abgelaufen'};
  return `<span class="tag ${m[s]||'tag-blue'}">${l[s]||s}</span>`;
}
function warnBar(level) {
  let h='<div class="warn-bar">';
  for(let i=1;i<=5;i++) h+=`<div class="warn-dot ${i<=level?(level>=4?'red':'active'):''}"></div>`;
  return h+'</div>';
}
function fmtDate(d) {
  if(!d) return '—';
  // Firestore Timestamp
  if(d && d.toDate) d = d.toDate().toISOString().split('T')[0];
  return new Date(d).toLocaleDateString('de-DE',{day:'2-digit',month:'short',year:'numeric'});
}

