window.exportData = function() {
  const data={termine,funds,bans,warns,members,announcements,tickets,activities,exportedAt:new Date().toISOString()};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=`necos-dashboard-backup-${new Date().toISOString().split('T')[0]}.json`;
  a.click();
  showToast('Export gestartet!','success');
};

