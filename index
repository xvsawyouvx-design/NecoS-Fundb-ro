<script type="module">
// ════════════════════════════════════════════════════════════════
//  🔥 FIREBASE KONFIGURATION
//  Ersetze dieses Objekt mit deinen Werten aus der Firebase Console!
//  Schritt: Firebase Console → Projektübersicht → </> → deine Config
// ════════════════════════════════════════════════════════════════
const FIREBASE_CONFIG = {
  apiKey: "DEIN_API_KEY",
  authDomain: "DEIN_PROJEKT.firebaseapp.com",
  projectId: "DEIN_PROJEKT_ID",
  storageBucket: "DEIN_PROJEKT.appspot.com",
  messagingSenderId: "DEINE_SENDER_ID",
  appId: "DEINE_APP_ID"
};
// ════════════════════════════════════════════════════════════════

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import {
  getFirestore, collection, addDoc, getDocs, deleteDoc, doc,
  updateDoc, onSnapshot, query, orderBy, serverTimestamp
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

// ── STATE ──
let db = null;
let isFirebaseReady = false;
let modName = localStorage.getItem('modName') || 'NecoS';

// Local cache
let termine = [], funds = [], bans = [], warns = [], members = [], announcements = [], tickets = [], activities = [];
let calDate = new Date();

// ── INIT FIREBASE ──
async function initFirebase() {
  const isDemo = FIREBASE_CONFIG.apiKey === 'DEIN_API_KEY';

  document.getElementById('loading-text').textContent = isDemo
    ? 'Demo-Modus wird gestartet...'
    : 'Verbinde mit Firebase...';

  await new Promise(r => setTimeout(r, 800));

  if (!isDemo) {
    try {
      const app = initializeApp(FIREBASE_CONFIG);
      db = getFirestore(app);
      isFirebaseReady = true;
      document.getElementById('sync-status').textContent = '🟢 Live-Sync aktiv';
      document.getElementById('live-dot').style.opacity = '1';
      document.getElementById('firebase-status-box').textContent = '🟢 Firebase verbunden – Daten werden in Echtzeit synchronisiert';
      document.getElementById('firebase-status-box').className = 'info-box blue';
      document.getElementById('setup-banner').style.display = 'none';
      setupListeners();
    } catch(e) {
      showToast('Firebase Fehler: ' + e.message, 'error');
      startDemoMode();
    }
  } else {
    startDemoMode();
  }

  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('setting-modname').value = modName;
  document.getElementById('b-mod').value = modName;
  document.getElementById('w-mod').value = modName;
  document.getElementById('a-author').value = modName;
  document.getElementById('sidebar-name').textContent = modName;
  document.getElementById('sidebar-avatar').textContent = modName[0].toUpperCase();
  document.getElementById('t-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('f-date').value = new Date().toISOString().split('T')[0];
  renderCalendar();
}

function startDemoMode() {
  showToast('Demo-Modus: Daten werden nicht gespeichert', 'info');
  // Load demo data
  termine = [{id:'d1',title:'Server-Meeting',date:'2025-06-10',time:'18:00',type:'meeting',desc:'Monatliches Meeting',org:'NecoS',createdAt:Date.now()}];
  funds = [{id:'d1',name:'Schlüsselbund',icon:'🔑',date:'2025-05-28',loc:'#allgemein',desc:'Schwarzer Schlüsselbund',reporter:'Pixel_Fox',status:'offen',createdAt:Date.now()}];
  bans = [{id:'d1',user:'SpamBot#1234',discordId:'111222333',reason:'Spam/Werbung',note:'Wiederholter Spam',duration:'Permanent',mod:'NecoS',date:'2025-04-20',status:'aktiv',createdAt:Date.now()}];
  warns = [{id:'d1',user:'Rulebreaker_X',reason:'Regelverstoß',mod:'NecoS',note:'Details',date:'2025-04-15',level:2,createdAt:Date.now()}];
  members = [
    {id:'d1',name:'NecoS',role:'Admin',color:'#5865F2',roles:['Admin'],createdAt:Date.now()},
    {id:'d2',name:'Pixel_Fox',role:'Moderator',color:'#43b581',roles:['Moderator'],createdAt:Date.now()},
  ];
  activities = [
    {icon:'🔨',color:'rgba(240,71,71,0.15)',text:'<strong>NecoS</strong> hat <strong>SpamBot#1234</strong> gebannt',time:'Vor 2 Stunden'},
    {icon:'📅',color:'rgba(88,101,242,0.15)',text:'<strong>NecoS</strong> hat Termin <strong>Server-Meeting</strong> erstellt',time:'Gestern'},
  ];
  renderAll();
}

// ── FIRESTORE LISTENERS (Echtzeit-Sync) ──
function setupListeners() {
  const cols = ['termine','funds','bans','warns','members','announcements','tickets','activities'];
  cols.forEach(col => {
    onSnapshot(query(collection(db, col), orderBy('createdAt','desc')), snap => {
      const data = snap.docs.map(d => ({id:d.id,...d.data()}));
      if(col==='termine') termine=data;
      else if(col==='funds') funds=data;
      else if(col==='bans') bans=data;
      else if(col==='warns') warns=data;
      else if(col==='members') members=data;
      else if(col==='announcements') announcements=data;
      else if(col==='tickets') tickets=data;
      else if(col==='activities') activities=data;
      renderAll();
    });
  });
}

// ── DB HELPERS ──
async function dbAdd(col, data) {
  if(!isFirebaseReady) return { id: 'local_' + Date.now() };
  return await addDoc(collection(db, col), { ...data, createdAt: serverTimestamp() });
}
async function dbDelete(col, id) {
  if(!isFirebaseReady) return;
  await deleteDoc(doc(db, col, id));
}
async function dbUpdate(col, id, data) {
  if(!isFirebaseReady) return;
  await updateDoc(doc(db, col, id), data);
}
async function logActivity(icon, color, text) {
  const entry = { icon, color, text, time: new Date().toLocaleString('de-DE',{hour:'2-digit',minute:'2-digit'}), createdAt: isFirebaseReady ? serverTimestamp() : Date.now() };
  if(!isFirebaseReady) { activities.unshift(entry); renderDashboard(); return; }
  await dbAdd('activities', entry);
}

// ── RENDER ALL ──
function renderAll() {
  renderDashboard(); renderTermine(); renderFund(); renderBans();
  renderWarns(); renderMembers(); renderAnn(); renderTickets(); renderCalendar();
