<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NecoS | Fundbüro – Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Exo+2:wght@300;400;500;600&display=swap" rel="stylesheet">

<!--
╔══════════════════════════════════════════════════════════════════╗
║         NECOS FUNDBÜRO DASHBOARD – FIREBASE SETUP GUIDE         ║
╠══════════════════════════════════════════════════════════════════╣
║                                                                  ║
║  SCHRITT 1 – FIREBASE PROJEKT ERSTELLEN (kostenlos)             ║
║  ─────────────────────────────────────────────────────────────  ║
║  1. Gehe zu: https://console.firebase.google.com                 ║
║  2. Klick "Projekt hinzufügen" → Name: necos-fundburo            ║
║  3. Google Analytics: kann deaktiviert werden                    ║
║  4. "Projekt erstellen" klicken                                  ║
║                                                                  ║
║  SCHRITT 2 – FIRESTORE DATENBANK                                 ║
║  ─────────────────────────────────────────────────────────────  ║
║  1. Links im Menü: "Firestore Database" klicken                  ║
║  2. "Datenbank erstellen" → "Im Testmodus starten" wählen        ║
║     (gibt dir 30 Tage open access, danach Regeln anpassen)       ║
║  3. Standort: eur3 (Europe) wählen → Fertig                      ║
║                                                                  ║
║  SCHRITT 3 – WEB-APP KONFIGURATION                               ║
║  ─────────────────────────────────────────────────────────────  ║
║  1. Projektübersicht → </> Web-Symbol klicken                    ║
║  2. App-Name: "necos-dashboard" → Registrieren                   ║
║  3. Du bekommst ein firebaseConfig Objekt, z.B.:                 ║
║     const firebaseConfig = {                                     ║
║       apiKey: "AIza...",                                         ║
║       authDomain: "...",                                         ║
║       projectId: "...",                                          ║
║       ...                                                        ║
║     }                                                            ║
║  4. ERSETZE den FIREBASE_CONFIG Block weiter unten im Code!      ║
║                                                                  ║
║  SCHRITT 4 – AUF GITHUB PAGES HOSTEN                             ║
║  ─────────────────────────────────────────────────────────────  ║
║  1. github.com → New Repository: necos-dashboard (Public)        ║
║  2. Diese Datei umbenennen zu: index.html                        ║
║  3. Datei hochladen → Settings → Pages → Branch: main → Save     ║
║  4. Link teilen: https://DEINNAME.github.io/necos-dashboard      ║
║                                                                  ║
║  SCHRITT 5 – FIRESTORE SICHERHEITSREGELN (nach 30 Tagen)        ║
║  ─────────────────────────────────────────────────────────────  ║
║  Firebase Console → Firestore → Regeln → einfügen:              ║
║                                                                  ║
║  rules_version = '2';                                            ║
║  service cloud.firestore {                                       ║
║    match /databases/{database}/documents {                       ║
║      match /{document=**} {                                      ║
║        allow read: if true;                                      ║
║        allow write: if true; // Oder IP/Auth beschränken         ║
║      }                                                           ║
║    }                                                             ║
║  }                                                               ║
╚══════════════════════════════════════════════════════════════════╝
-->

<style>
  :root {
    --bg: #0a0b0f; --surface: #111318; --surface2: #181b22; --surface3: #1f2330;
    --border: #2a2f3f; --accent: #5865F2; --accent2: #7289da;
    --gold: #ffd700; --green: #43b581; --red: #f04747; --orange: #faa61a;
    --text: #e8eaf2; --text2: #8b91a8; --text3: #555c72;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html, body { height:100%; }
  body { font-family:'Exo 2',sans-serif; background:var(--bg); color:var(--text); display:flex; min-height:100vh; overflow-x:hidden; }

  /* ── SETUP BANNER ── */
  #setup-banner {
    position:fixed; top:0; left:0; right:0; z-index:999;
    background:linear-gradient(90deg,rgba(250,166,26,0.15),rgba(88,101,242,0.15));
    border-bottom:2px solid var(--orange);
    padding:10px 24px; display:flex; align-items:center; gap:14px; flex-wrap:wrap;
  }
  #setup-banner .sb-icon { font-size:20px; }
  #setup-banner .sb-text { flex:1; font-size:13px; color:var(--orange); font-weight:600; }
  #setup-banner .sb-text span { color:var(--text2); font-weight:400; }
  #setup-banner .sb-close { background:none; border:1px solid var(--orange); color:var(--orange); padding:4px 12px; border-radius:6px; cursor:pointer; font-size:12px; font-weight:600; }
  #setup-banner .sb-close:hover { background:var(--orange); color:#000; }

  /* ── LOADING ── */
  #loading-screen {
    position:fixed; inset:0; background:var(--bg); z-index:500;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px;
  }
  .spinner {
    width:40px; height:40px; border:3px solid var(--border);
    border-top-color:var(--accent); border-radius:50%; animation:spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform:rotate(360deg); } }
  #loading-screen p { color:var(--text2); font-size:14px; }

  /* ── SIDEBAR ── */
  .sidebar {
    width:240px; min-height:100vh; background:var(--surface); border-right:1px solid var(--border);
    display:flex; flex-direction:column; position:fixed; top:0; left:0; z-index:100; padding-bottom:20px;
  }
  .sidebar-logo { padding:24px 20px 20px; border-bottom:1px solid var(--border); }
  .sidebar-logo .server-name { font-family:'Rajdhani',sans-serif; font-size:17px; font-weight:700; color:var(--accent2); letter-spacing:0.04em; line-height:1.2; }
  .sidebar-logo .server-sub { font-size:11px; color:var(--text3); margin-top:2px; letter-spacing:0.08em; text-transform:uppercase; }
  .online-badge { display:inline-flex; align-items:center; gap:5px; background:rgba(67,181,129,0.1); border:1px solid rgba(67,181,129,0.25); border-radius:20px; padding:2px 9px; font-size:11px; color:var(--green); margin-top:8px; }
  .online-badge::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--green); }
  .sync-badge { display:inline-flex; align-items:center; gap:5px; background:rgba(88,101,242,0.1); border:1px solid rgba(88,101,242,0.25); border-radius:20px; padding:2px 9px; font-size:10px; color:var(--accent2); margin-top:4px; }
  .nav-section { padding:16px 12px 4px; font-size:10px; color:var(--text3); letter-spacing:0.12em; text-transform:uppercase; font-weight:600; }
  .nav-item { display:flex; align-items:center; gap:10px; padding:9px 16px; margin:1px 8px; border-radius:8px; cursor:pointer; color:var(--text2); font-size:14px; font-weight:500; transition:all 0.18s; }
  .nav-item:hover { background:var(--surface2); color:var(--text); }
  .nav-item.active { background:rgba(88,101,242,0.15); color:var(--accent2); border-left:3px solid var(--accent); margin-left:8px; padding-left:13px; }
  .nav-item .icon { font-size:16px; min-width:18px; text-align:center; }
  .nav-badge { margin-left:auto; background:var(--red); color:#fff; font-size:10px; font-weight:700; padding:1px 6px; border-radius:20px; min-width:18px; text-align:center; }
  .nav-badge.green { background:var(--green); }
  .nav-badge.orange { background:var(--orange); }
  .sidebar-footer { margin-top:auto; padding:16px; border-top:1px solid var(--border); display:flex; align-items:center; gap:10px; }
  .avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,var(--accent),#9b59b6); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; color:#fff; flex-shrink:0; }
  .user-info .name { font-size:13px; font-weight:600; }
  .user-info .role { font-size:11px; color:var(--gold); }

  /* ── MAIN ── */
  .main { margin-left:240px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
  .topbar { padding:18px 32px; border-bottom:1px solid var(--border); background:var(--surface); display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; }
  .topbar-title { font-family:'Rajdhani',sans-serif; font-size:22px; font-weight:700; letter-spacing:0.03em; display:flex; align-items:center; gap:10px; }
  .live-dot { width:8px; height:8px; border-radius:50%; background:var(--green); animation:pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
  .topbar-actions { display:flex; gap:10px; }
  .btn { padding:8px 18px; border-radius:8px; border:none; cursor:pointer; font-family:'Exo 2',sans-serif; font-size:13px; font-weight:600; transition:all 0.18s; display:inline-flex; align-items:center; gap:6px; }
  .btn-primary { background:var(--accent); color:#fff; }
  .btn-primary:hover { background:#4752c4; box-shadow:0 0 16px rgba(88,101,242,0.4); }
  .btn-secondary { background:var(--surface3); color:var(--text); border:1px solid var(--border); }
  .btn-secondary:hover { background:var(--border); }
  .btn-danger { background:rgba(240,71,71,0.15); color:var(--red); border:1px solid rgba(240,71,71,0.3); }
  .btn-danger:hover { background:rgba(240,71,71,0.25); }
  .btn-success { background:rgba(67,181,129,0.15); color:var(--green); border:1px solid rgba(67,181,129,0.3); }
  .btn-success:hover { background:rgba(67,181,129,0.25); }
  .btn-sm { padding:5px 12px; font-size:12px; }
  .btn:disabled { opacity:0.4; cursor:not-allowed; }

  /* ── CONTENT ── */
  .content { padding:28px 32px; flex:1; }
  .page { display:none; }
  .page.active { display:block; animation:fadeIn 0.25s ease; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

  /* ── STATS ── */
  .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
  .stat-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px; position:relative; overflow:hidden; transition:border-color 0.2s; }
  .stat-card:hover { border-color:var(--accent2); }
  .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
  .stat-card.blue::before { background:var(--accent); }
  .stat-card.green::before { background:var(--green); }
  .stat-card.red::before { background:var(--red); }
  .stat-card.gold::before { background:var(--gold); }
  .stat-label { font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:8px; }
  .stat-value { font-family:'Rajdhani',sans-serif; font-size:36px; font-weight:700; line-height:1; }
  .stat-value.blue{color:var(--accent2)} .stat-value.green{color:var(--green)} .stat-value.red{color:var(--red)} .stat-value.gold{color:var(--gold)}
  .stat-sub { font-size:12px; color:var(--text3); margin-top:6px; }

  /* ── GRID ── */
  .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  .grid-3 { display:grid; grid-template-columns:2fr 1fr; gap:20px; }

  /* ── CARD ── */
  .card { background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
  .card-header { padding:16px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .card-title { font-family:'Rajdhani',sans-serif; font-size:16px; font-weight:700; letter-spacing:0.03em; display:flex; align-items:center; gap:8px; }
  .card-body { padding:20px; }

  /* ── TABLE ── */
  .table-wrap { overflow-x:auto; }
  table { width:100%; border-collapse:collapse; }
  th { text-align:left; padding:10px 14px; font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:0.1em; border-bottom:1px solid var(--border); font-weight:600; }
  td { padding:12px 14px; font-size:13px; border-bottom:1px solid rgba(42,47,63,0.5); vertical-align:middle; }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(88,101,242,0.04); }

  /* ── TAGS ── */
  .tag { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; }
  .tag-blue{background:rgba(88,101,242,0.15);color:var(--accent2);border:1px solid rgba(88,101,242,0.3)}
  .tag-green{background:rgba(67,181,129,0.13);color:var(--green);border:1px solid rgba(67,181,129,0.25)}
  .tag-red{background:rgba(240,71,71,0.13);color:var(--red);border:1px solid rgba(240,71,71,0.25)}
  .tag-orange{background:rgba(250,166,26,0.13);color:var(--orange);border:1px solid rgba(250,166,26,0.25)}
  .tag-gold{background:rgba(255,215,0,0.1);color:var(--gold);border:1px solid rgba(255,215,0,0.25)}

  /* ── MODAL ── */
  .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.7); backdrop-filter:blur(4px); z-index:200; display:none; align-items:center; justify-content:center; }
  .modal-overlay.open { display:flex; animation:fadeIn 0.18s ease; }
  .modal { background:var(--surface2); border:1px solid var(--border); border-radius:16px; width:520px; max-width:95vw; max-height:90vh; overflow-y:auto; box-shadow:0 25px 60px rgba(0,0,0,0.5); }
  .modal-header { padding:20px 24px 16px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .modal-title { font-family:'Rajdhani',sans-serif; font-size:18px; font-weight:700; }
  .modal-close { background:none; border:none; color:var(--text3); cursor:pointer; font-size:20px; line-height:1; transition:color 0.15s; }
  .modal-close:hover { color:var(--text); }
  .modal-body { padding:20px 24px; }
  .modal-footer { padding:16px 24px; border-top:1px solid var(--border); display:flex; gap:10px; justify-content:flex-end; }

  /* ── FORM ── */
  .form-group { margin-bottom:16px; }
  .form-label { display:block; font-size:12px; color:var(--text2); margin-bottom:6px; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; }
  .form-control { width:100%; padding:10px 14px; background:var(--surface3); border:1px solid var(--border); border-radius:8px; color:var(--text); font-family:'Exo 2',sans-serif; font-size:14px; transition:border-color 0.18s; outline:none; }
  .form-control:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(88,101,242,0.15); }
  .form-control option { background:var(--surface3); }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

  /* ── CALENDAR ── */
  .calendar { padding:8px; }
  .cal-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .cal-header span { font-family:'Rajdhani',sans-serif; font-weight:700; font-size:16px; }
  .cal-header button { background:none; border:none; color:var(--text2); cursor:pointer; font-size:16px; padding:4px 8px; border-radius:6px; transition:background 0.15s; }
  .cal-header button:hover { background:var(--surface3); }
  .cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:2px; }
  .cal-dayname { text-align:center; font-size:11px; color:var(--text3); padding:4px; text-transform:uppercase; font-weight:600; }
  .cal-day { text-align:center; padding:6px 4px; border-radius:6px; cursor:pointer; font-size:13px; font-weight:500; transition:all 0.15s; position:relative; }
  .cal-day:hover { background:var(--surface3); }
  .cal-day.today { background:rgba(88,101,242,0.2); color:var(--accent2); font-weight:700; }
  .cal-day.has-event::after { content:''; position:absolute; bottom:2px; left:50%; transform:translateX(-50%); width:4px; height:4px; border-radius:50%; background:var(--accent); }
  .cal-day.empty { cursor:default; }

  /* ── EVENT ITEMS ── */
  .event-item { display:flex; align-items:flex-start; gap:12px; padding:12px; border-radius:8px; background:var(--surface3); border:1px solid var(--border); margin-bottom:10px; transition:border-color 0.18s; }
  .event-item:hover { border-color:var(--accent2); }
  .event-date-box { background:rgba(88,101,242,0.15); border:1px solid rgba(88,101,242,0.3); border-radius:8px; padding:6px 10px; text-align:center; min-width:48px; flex-shrink:0; }
  .event-date-box .day { font-family:'Rajdhani',sans-serif; font-size:22px; font-weight:700; color:var(--accent2); line-height:1; }
  .event-date-box .month { font-size:10px; color:var(--text3); text-transform:uppercase; }
  .event-info { flex:1; }
  .event-title { font-weight:600; font-size:14px; margin-bottom:3px; }
  .event-meta { font-size:12px; color:var(--text2); display:flex; gap:12px; flex-wrap:wrap; }
  .event-actions { display:flex; gap:6px; align-items:center; }

  /* ── ACTIVITY ── */
  .activity-item { display:flex; gap:12px; padding:10px 0; border-bottom:1px solid rgba(42,47,63,0.5); align-items:flex-start; }
  .activity-item:last-child { border-bottom:none; }
  .activity-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; }
  .activity-text { font-size:13px; line-height:1.5; }
  .activity-text strong { color:var(--accent2); }
  .activity-time { font-size:11px; color:var(--text3); margin-top:2px; }

  /* ── LOST ITEMS ── */
  .lost-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:14px; }
  .lost-card { background:var(--surface3); border:1px solid var(--border); border-radius:10px; padding:14px; transition:all 0.18s; }
  .lost-card:hover { border-color:var(--accent2); transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,0.25); }
  .lost-card .item-icon { font-size:28px; margin-bottom:8px; }
  .lost-card .item-name { font-weight:600; font-size:14px; margin-bottom:4px; }
  .lost-card .item-meta { font-size:11px; color:var(--text2); }
  .lost-card .item-status { margin-top:10px; }

  /* ── MEMBERS ── */
  .member-item { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid rgba(42,47,63,0.5); }
  .member-item:last-child { border-bottom:none; }
  .member-avatar { width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; flex-shrink:0; }
  .member-info { flex:1; }
  .member-name { font-size:14px; font-weight:600; }
  .member-roles { font-size:11px; color:var(--text3); margin-top:2px; }
  .member-actions { display:flex; gap:6px; }

  /* ── TABS ── */
  .tabs { display:flex; gap:4px; margin-bottom:20px; border-bottom:1px solid var(--border); }
  .tab { padding:9px 18px; font-size:13px; font-weight:600; cursor:pointer; color:var(--text2); border-bottom:2px solid transparent; margin-bottom:-1px; transition:all 0.18s; border-radius:6px 6px 0 0; }
  .tab:hover { color:var(--text); background:rgba(88,101,242,0.07); }
  .tab.active { color:var(--accent2); border-bottom-color:var(--accent); }
  .tab-content { display:none; }
  .tab-content.active { display:block; animation:fadeIn 0.2s; }

  /* ── MISC ── */
  .filter-bar { display:flex; gap:10px; margin-bottom:20px; align-items:center; flex-wrap:wrap; }
  .search-wrap { position:relative; flex:1; min-width:180px; }
  .search-input { width:100%; padding:9px 14px 9px 36px; background:var(--surface3); border:1px solid var(--border); border-radius:8px; color:var(--text); font-family:'Exo 2',sans-serif; font-size:13px; outline:none; transition:border-color 0.18s; }
  .search-input:focus { border-color:var(--accent); }
  .search-wrap::before { content:'🔍'; position:absolute; left:11px; top:50%; transform:translateY(-50%); font-size:13px; pointer-events:none; }
  .page-header { margin-bottom:24px; }
  .page-header h1 { font-family:'Rajdhani',sans-serif; font-size:26px; font-weight:700; margin-bottom:4px; }
  .page-header p { color:var(--text2); font-size:14px; }
  .empty-state { text-align:center; padding:40px 20px; color:var(--text3); }
  .empty-state .icon { font-size:40px; margin-bottom:12px; }
  .empty-state p { font-size:14px; }
  .announcement { background:linear-gradient(135deg,rgba(88,101,242,0.12),rgba(155,89,182,0.08)); border:1px solid rgba(88,101,242,0.25); border-radius:12px; padding:16px 20px; margin-bottom:16px; position:relative; overflow:hidden; }
  .announcement::before { content:''; position:absolute; top:0; left:0; width:4px; height:100%; background:var(--accent); }
  .announcement .ann-title { font-weight:700; font-size:14px; margin-bottom:4px; color:var(--accent2); }
  .announcement .ann-text { font-size:13px; color:var(--text2); }
  .announcement .ann-meta { font-size:11px; color:var(--text3); margin-top:8px; }
  .warn-bar { display:flex; gap:3px; }
  .warn-dot { width:10px; height:10px; border-radius:2px; background:var(--surface3); border:1px solid var(--border); }
  .warn-dot.active { background:var(--orange); border-color:var(--orange); }
  .warn-dot.red { background:var(--red); border-color:var(--red); }
  .info-box { border-radius:8px; padding:12px 16px; font-size:13px; margin-bottom:16px; display:flex; gap:10px; align-items:flex-start; }
  .info-box.orange { background:rgba(250,166,26,0.1); border:1px solid rgba(250,166,26,0.25); color:var(--orange); }
  .info-box.blue { background:rgba(88,101,242,0.1); border:1px solid rgba(88,101,242,0.25); color:var(--accent2); }
  ::-webkit-scrollbar { width:6px; height:6px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }

  /* ── TOAST ── */
  #toast { position:fixed; bottom:24px; right:24px; z-index:999; display:flex; flex-direction:column; gap:8px; }
  .toast-item { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:12px 18px; font-size:13px; min-width:220px; animation:slideIn 0.3s ease; box-shadow:0 8px 24px rgba(0,0,0,0.4); display:flex; align-items:center; gap:10px; }
  @keyframes slideIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:none} }
  .toast-item.success { border-left:3px solid var(--green); }
  .toast-item.error { border-left:3px solid var(--red); }
  .toast-item.info { border-left:3px solid var(--accent); }
</style>
</head>
<body>

<!-- SETUP BANNER -->
<div id="setup-banner">
  <span class="sb-icon">⚠️</span>
  <div class="sb-text">
    Firebase nicht konfiguriert – Dashboard läuft im <strong>Offline-Demo-Modus</strong>.
    <span>Ersetze die FIREBASE_CONFIG im &lt;script&gt; Tag mit deinen Werten.</span>
  </div>
  <button class="sb-close" onclick="this.parentElement.style.display='none'">Verstanden</button>
</div>

<!-- LOADING -->
<div id="loading-screen">
  <div class="spinner"></div>
  <p id="loading-text">Verbinde mit Firebase...</p>
</div>

<!-- TOAST -->
<div id="toast"></div>

<!-- SIDEBAR -->
<aside class="sidebar" style="margin-top:48px;">
  <div class="sidebar-logo">
    <div class="server-name">NecoS | Fundbüro</div>
    <div class="server-sub">Server Dashboard</div>
    <div class="online-badge">Online</div>
    <div class="sync-badge" id="sync-status">🔴 Offline-Modus</div>
  </div>
  <div class="nav-section">Übersicht</div>
  <div class="nav-item active" onclick="showPage('dashboard',this)"><span class="icon">🏠</span> Dashboard</div>
  <div class="nav-item" onclick="showPage('termine',this)"><span class="icon">📅</span> Termine <span class="nav-badge green" id="badge-termine">0</span></div>
  <div class="nav-item" onclick="showPage('fundbüro',this)"><span class="icon">🔍</span> Fundbüro <span class="nav-badge orange" id="badge-fund">0</span></div>
  <div class="nav-section">Moderation</div>
  <div class="nav-item" onclick="showPage('bans',this)"><span class="icon">🔨</span> Bans <span class="nav-badge" id="badge-bans">0</span></div>
  <div class="nav-item" onclick="showPage('verwarnungen',this)"><span class="icon">⚠️</span> Verwarnungen</div>
  <div class="nav-item" onclick="showPage('mitglieder',this)"><span class="icon">👥</span> Mitglieder</div>
  <div class="nav-section">Server</div>
  <div class="nav-item" onclick="showPage('ankuendigungen',this)"><span class="icon">📢</span> Ankündigungen</div>
  <div class="nav-item" onclick="showPage('tickets',this)"><span class="icon">🎫</span> Tickets <span class="nav-badge" id="badge-tickets">0</span></div>
  <div class="nav-item" onclick="showPage('einstellungen',this)"><span class="icon">⚙️</span> Einstellungen</div>
  <div class="sidebar-footer">
    <div class="avatar" id="sidebar-avatar">N</div>
    <div class="user-info">
      <div class="name" id="sidebar-name">NecoS</div>
      <div class="role">⭐ Admin</div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main" style="margin-top:48px;">
  <div class="topbar">
    <div class="topbar-title">
      <span id="topbar-title">🏠 Dashboard</span>
      <div class="live-dot" id="live-dot" style="opacity:0;" title="Live-Sync aktiv"></div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-secondary btn-sm" onclick="showPage('tickets',null)">🎫 Tickets (<span id="ticket-count">0</span>)</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-schnell')">+ Schnellaktion</button>
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="stats-grid">
        <div class="stat-card blue"><div class="stat-label">Mitglieder</div><div class="stat-value blue" id="stat-members">—</div><div class="stat-sub">Eingetragen</div></div>
        <div class="stat-card green"><div class="stat-label">Termine</div><div class="stat-value green" id="stat-termine">—</div><div class="stat-sub">Anstehend</div></div>
        <div class="stat-card red"><div class="stat-label">Aktive Bans</div><div class="stat-value red" id="stat-bans">—</div><div class="stat-sub">Gesperrt</div></div>
        <div class="stat-card gold"><div class="stat-label">Fund-Einträge</div><div class="stat-value gold" id="stat-fund">—</div><div class="stat-sub">Offen</div></div>
      </div>
      <div class="grid-3">
        <div>
          <div class="card" style="margin-bottom:20px;">
            <div class="card-header">
              <div class="card-title">📅 Nächste Termine</div>
              <button class="btn btn-primary btn-sm" onclick="openModal('modal-termin')">+ Neu</button>
            </div>
            <div class="card-body" id="dash-termine"><div class="empty-state"><div class="icon">📅</div><p>Wird geladen...</p></div></div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">⚡ Letzte Aktivität</div></div>
            <div class="card-body" id="dash-activity"><div class="empty-state"><div class="icon">⚡</div><p>Wird geladen...</p></div></div>
          </div>
        </div>
        <div>
          <div class="card" style="margin-bottom:20px;">
            <div class="card-header"><div class="card-title">🎫 Offene Tickets</div></div>
            <div class="card-body" id="dash-tickets"><div class="empty-state"><p>Keine Tickets</p></div></div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">🔍 Fundbüro (Offen)</div></div>
            <div class="card-body" id="dash-fund"><div class="empty-state"><p>Keine offenen Funde</p></div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- TERMINE -->
    <div class="page" id="page-termine">
      <div class="page-header"><h1>📅 Terminverwaltung</h1><p>Events, Meetings und Veranstaltungen</p></div>
      <div class="grid-2" style="margin-bottom:20px;">
        <div class="card">
          <div class="card-header"><div class="card-title">📆 Kalender</div><button class="btn btn-primary btn-sm" onclick="openModal('modal-termin')">+ Erstellen</button></div>
          <div class="card-body"><div class="calendar" id="calendar"></div></div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">📋 Alle Termine</div></div>
          <div class="card-body" id="termine-list"></div>
        </div>
      </div>
    </div>

    <!-- FUNDBÜRO -->
    <div class="page" id="page-fundbüro">
      <div class="page-header"><h1>🔍 Fundbüro</h1><p>Gefundene und vermisste Gegenstände</p></div>
      <div class="filter-bar">
        <div class="search-wrap"><input class="search-input" type="text" placeholder="Suche nach Gegenstand..." oninput="filterFund(this.value)"></div>
        <select class="form-control" style="width:160px;" onchange="filterFundStatus(this.value)">
          <option value="">Alle Status</option><option value="offen">Offen</option><option value="gefunden">Gefunden</option><option value="abgeholt">Abgeholt</option>
        </select>
        <button class="btn btn-primary" onclick="openModal('modal-fund')">+ Eintrag hinzufügen</button>
      </div>
      <div class="lost-grid" id="fund-grid"></div>
    </div>

    <!-- BANS -->
    <div class="page" id="page-bans">
      <div class="page-header"><h1>🔨 Bans & Sperren</h1><p>Alle gesperrten Nutzer</p></div>
      <div class="filter-bar">
        <div class="search-wrap"><input class="search-input" type="text" placeholder="Nutzer suchen..." oninput="filterBans(this.value)"></div>
        <button class="btn btn-danger" onclick="openModal('modal-ban')">🔨 Ban eintragen</button>
      </div>
      <div class="card">
        <div class="table-wrap">
          <table><thead><tr><th>Nutzer</th><th>Moderator</th><th>Grund</th><th>Datum</th><th>Dauer</th><th>Status</th><th>Aktionen</th></tr></thead>
          <tbody id="ban-body"></tbody></table>
        </div>
      </div>
    </div>

    <!-- VERWARNUNGEN -->
    <div class="page" id="page-verwarnungen">
      <div class="page-header"><h1>⚠️ Verwarnungen</h1><p>Moderationslog und Verwarnungshistorie</p></div>
      <div class="filter-bar">
        <div class="search-wrap"><input class="search-input" type="text" placeholder="Nutzer suchen..."></div>
        <button class="btn btn-secondary" style="border-color:var(--orange);color:var(--orange);" onclick="openModal('modal-warn')">⚠️ Verwarnung</button>
      </div>
      <div class="card">
        <div class="table-wrap">
          <table><thead><tr><th>Nutzer</th><th>Mod</th><th>Grund</th><th>Level</th><th>Datum</th><th>Aktionen</th></tr></thead>
          <tbody id="warn-body"></tbody></table>
        </div>
      </div>
    </div>

    <!-- MITGLIEDER -->
    <div class="page" id="page-mitglieder">
      <div class="page-header"><h1>👥 Mitgliederverwaltung</h1><p>Alle Servermitglieder und ihre Rollen</p></div>
      <div class="filter-bar">
        <div class="search-wrap"><input class="search-input" type="text" placeholder="Mitglied suchen..." oninput="filterMembers(this.value)"></div>
        <button class="btn btn-primary" onclick="openModal('modal-member')">+ Mitglied hinzufügen</button>
      </div>
      <div class="card"><div class="card-body" id="member-list"></div></div>
    </div>

    <!-- ANKÜNDIGUNGEN -->
    <div class="page" id="page-ankuendigungen">
      <div class="page-header"><h1>📢 Ankündigungen</h1><p>Server-Nachrichten und wichtige Hinweise</p></div>
      <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
        <button class="btn btn-primary" onclick="openModal('modal-ann')">📢 Neue Ankündigung</button>
      </div>
      <div id="ann-list"></div>
    </div>

    <!-- TICKETS -->
    <div class="page" id="page-tickets">
      <div class="page-header"><h1>🎫 Support-Tickets</h1><p>Offene und bearbeitete Mitgliederanfragen</p></div>
      <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
        <button class="btn btn-primary" onclick="openModal('modal-ticket')">🎫 Ticket erstellen</button>
      </div>
      <div class="tabs">
        <div class="tab active" onclick="switchTab('tab-offen',this)">Offen (<span id="tab-offen-count">0</span>)</div>
        <div class="tab" onclick="switchTab('tab-bearbeitung',this)">In Bearbeitung</div>
        <div class="tab" onclick="switchTab('tab-geschlossen',this)">Geschlossen</div>
      </div>
      <div class="tab-content active" id="tab-offen">
        <div class="card"><div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Nutzer</th><th>Betreff</th><th>Kategorie</th><th>Erstellt</th><th>Aktionen</th></tr></thead>
          <tbody id="ticket-body-offen"></tbody>
        </table></div></div>
      </div>
      <div class="tab-content" id="tab-bearbeitung"><div class="empty-state"><div class="icon">⏳</div><p>Keine Tickets in Bearbeitung</p></div></div>
      <div class="tab-content" id="tab-geschlossen"><div class="card"><div class="table-wrap"><table>
        <thead><tr><th>#</th><th>Nutzer</th><th>Betreff</th><th>Geschlossen am</th></tr></thead>
        <tbody id="ticket-body-closed"></tbody>
      </table></div></div></div>
    </div>

    <!-- EINSTELLUNGEN -->
    <div class="page" id="page-einstellungen">
      <div class="page-header"><h1>⚙️ Einstellungen</h1><p>Dashboard-Konfiguration</p></div>
      <div class="grid-2">
        <div class="card">
          <div class="card-header"><div class="card-title">🔥 Firebase Status</div></div>
          <div class="card-body">
            <div class="info-box blue" id="firebase-status-box">🔴 Nicht verbunden – konfiguriere Firebase im Script-Tag</div>
            <div class="form-group"><label class="form-label">Moderator-Name (wird bei Aktionen verwendet)</label>
              <input class="form-control" id="setting-modname" value="NecoS" placeholder="Dein Discord-Name">
            </div>
            <button class="btn btn-primary" onclick="saveSetting()">💾 Speichern</button>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">📊 Daten Export</div></div>
          <div class="card-body">
            <p style="font-size:13px;color:var(--text2);margin-bottom:12px;">Exportiere alle Daten als JSON-Datei (Backup)</p>
            <button class="btn btn-secondary" onclick="exportData()">⬇️ Alle Daten exportieren</button>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<!-- ============ MODALS ============ -->

<!-- Termin -->
<div class="modal-overlay" id="modal-termin">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">📅 Termin erstellen</div><button class="modal-close" onclick="closeModal('modal-termin')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Titel *</label><input class="form-control" id="t-title" placeholder="z.B. Server-Meeting"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Datum *</label><input class="form-control" id="t-date" type="date"></div>
        <div class="form-group"><label class="form-label">Uhrzeit</label><input class="form-control" id="t-time" type="time" value="18:00"></div>
      </div>
      <div class="form-group"><label class="form-label">Typ</label>
        <select class="form-control" id="t-type"><option value="event">🎉 Event</option><option value="meeting">💬 Meeting</option><option value="wartung">🔧 Wartung</option><option value="sonstiges">📌 Sonstiges</option></select>
      </div>
      <div class="form-group"><label class="form-label">Beschreibung</label><textarea class="form-control" id="t-desc" rows="3" placeholder="Details..."></textarea></div>
      <div class="form-group"><label class="form-label">Veranstalter</label><input class="form-control" id="t-org" placeholder="Discord-Name"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-termin')">Abbrechen</button>
      <button class="btn btn-primary" onclick="addTermin()">✅ Erstellen</button>
    </div>
  </div>
</div>

<!-- Fund -->
<div class="modal-overlay" id="modal-fund">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">🔍 Fund eintragen</div><button class="modal-close" onclick="closeModal('modal-fund')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Gegenstand *</label><input class="form-control" id="f-name" placeholder="z.B. Schlüsselbund"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Emoji</label><input class="form-control" id="f-icon" placeholder="🔑" maxlength="4"></div>
        <div class="form-group"><label class="form-label">Gefunden am</label><input class="form-control" id="f-date" type="date"></div>
      </div>
      <div class="form-group"><label class="form-label">Fundort</label><input class="form-control" id="f-loc" placeholder="z.B. #allgemein"></div>
      <div class="form-group"><label class="form-label">Beschreibung</label><textarea class="form-control" id="f-desc" rows="2" placeholder="Details..."></textarea></div>
      <div class="form-group"><label class="form-label">Gemeldet von</label><input class="form-control" id="f-reporter" placeholder="Discord-Name"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-fund')">Abbrechen</button>
      <button class="btn btn-primary" onclick="addFund()">✅ Eintragen</button>
    </div>
  </div>
</div>

<!-- Ban -->
<div class="modal-overlay" id="modal-ban">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">🔨 Ban eintragen</div><button class="modal-close" onclick="closeModal('modal-ban')">✕</button></div>
    <div class="modal-body">
      <div class="info-box orange">⚠️ Sorgfältig prüfen, bevor ein Ban eingetragen wird.</div>
      <div class="form-group"><label class="form-label">Nutzername *</label><input class="form-control" id="b-user" placeholder="Nutzername#0000"></div>
      <div class="form-group"><label class="form-label">Discord-ID</label><input class="form-control" id="b-id" placeholder="z.B. 123456789012345678"></div>
      <div class="form-group"><label class="form-label">Grund *</label>
        <select class="form-control" id="b-reason"><option>Spam/Werbung</option><option>Beleidigung</option><option>Regelverstoß</option><option>Betrug/Scam</option><option>NSFW-Content</option><option>Sonstiges</option></select>
      </div>
      <div class="form-group"><label class="form-label">Notiz</label><textarea class="form-control" id="b-note" rows="2" placeholder="Details..."></textarea></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Dauer</label>
          <select class="form-control" id="b-dur"><option>Permanent</option><option>7 Tage</option><option>14 Tage</option><option>30 Tage</option></select>
        </div>
        <div class="form-group"><label class="form-label">Moderator</label><input class="form-control" id="b-mod" placeholder="Mod-Name"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-ban')">Abbrechen</button>
      <button class="btn btn-danger" onclick="addBan()">🔨 Eintragen</button>
    </div>
  </div>
</div>

<!-- Warn -->
<div class="modal-overlay" id="modal-warn">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">⚠️ Verwarnung</div><button class="modal-close" onclick="closeModal('modal-warn')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Nutzer *</label><input class="form-control" id="w-user" placeholder="Nutzername"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Grund</label>
          <select class="form-control" id="w-reason"><option>Regelverstoß</option><option>Spam</option><option>Unhöfliches Verhalten</option><option>Off-Topic</option><option>Sonstiges</option></select>
        </div>
        <div class="form-group"><label class="form-label">Moderator</label><input class="form-control" id="w-mod" placeholder="Mod-Name"></div>
      </div>
      <div class="form-group"><label class="form-label">Notiz</label><textarea class="form-control" id="w-note" rows="2" placeholder="Details..."></textarea></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-warn')">Abbrechen</button>
      <button class="btn btn-secondary" style="border-color:var(--orange);color:var(--orange);" onclick="addWarn()">⚠️ Verwarnung</button>
    </div>
  </div>
</div>

<!-- Ankündigung -->
<div class="modal-overlay" id="modal-ann">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">📢 Ankündigung</div><button class="modal-close" onclick="closeModal('modal-ann')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Titel *</label><input class="form-control" id="a-title" placeholder="Überschrift"></div>
      <div class="form-group"><label class="form-label">Nachricht *</label><textarea class="form-control" id="a-text" rows="4" placeholder="Inhalt..."></textarea></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Kategorie</label>
          <select class="form-control" id="a-cat"><option>📢 Allgemein</option><option>🔧 Update</option><option>🎉 Event</option><option>⚠️ Wichtig</option><option>🔍 Fundbüro</option></select>
        </div>
        <div class="form-group"><label class="form-label">Von</label><input class="form-control" id="a-author" placeholder="Dein Name"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-ann')">Abbrechen</button>
      <button class="btn btn-primary" onclick="addAnn()">📢 Veröffentlichen</button>
    </div>
  </div>
</div>

<!-- Ticket -->
<div class="modal-overlay" id="modal-ticket">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">🎫 Ticket erstellen</div><button class="modal-close" onclick="closeModal('modal-ticket')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Nutzer *</label><input class="form-control" id="tk-user" placeholder="Discord-Name"></div>
      <div class="form-group"><label class="form-label">Betreff *</label><input class="form-control" id="tk-subject" placeholder="Worum geht es?"></div>
      <div class="form-group"><label class="form-label">Kategorie</label>
        <select class="form-control" id="tk-cat"><option>Rolle</option><option>Ban-Appeal</option><option>Support</option><option>Frage</option><option>Sonstiges</option></select>
      </div>
      <div class="form-group"><label class="form-label">Beschreibung</label><textarea class="form-control" id="tk-desc" rows="3" placeholder="Details..."></textarea></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-ticket')">Abbrechen</button>
      <button class="btn btn-primary" onclick="addTicket()">🎫 Erstellen</button>
    </div>
  </div>
</div>

<!-- Member -->
<div class="modal-overlay" id="modal-member">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">👤 Mitglied hinzufügen</div><button class="modal-close" onclick="closeModal('modal-member')">✕</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Discord-Name *</label><input class="form-control" id="m-name" placeholder="Nutzername"></div>
      <div class="form-group"><label class="form-label">Hauptrolle</label>
        <select class="form-control" id="m-role"><option>Mitglied</option><option>Moderator</option><option>Admin</option><option>VIP</option></select>
      </div>
      <div class="form-group"><label class="form-label">Farbe (Avatar)</label><input class="form-control" type="color" id="m-color" value="#5865F2" style="height:40px;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modal-member')">Abbrechen</button>
      <button class="btn btn-primary" onclick="addMember()">✅ Hinzufügen</button>
    </div>
  </div>
</div>

<!-- Schnellaktion -->
<div class="modal-overlay" id="modal-schnell">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">⚡ Schnellaktionen</div><button class="modal-close" onclick="closeModal('modal-schnell')">✕</button></div>
